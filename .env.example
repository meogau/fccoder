# Telegram Bot Configuration (for match result notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# How to set up Telegram notifications:
# 1. Create a new bot by messaging @BotFather on Telegram
# 2. Get the bot token and add it to TELEGRAM_BOT_TOKEN
# 3. Players need to start a conversation with your bot first
# 4. Implement chat ID mapping in your database

# AWS S3 Configuration (for image uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=ap-southeast-1

# How to set up AWS S3:
# 1. Create an AWS account and navigate to S3
# 2. Create a new bucket (e.g., fc-coder-uploads)
# 3. Create an IAM user with S3 permissions
# 4. Generate access keys for the IAM user
# 5. Add the credentials above
# 6. Make sure your bucket has proper CORS and public access settings if needed

# AWS DynamoDB Configuration (for database)
AWS_DYNAMODB_REGION=ap-southeast-1
DYNAMODB_PLAYERS_TABLE=FCCoder-Players
DYNAMODB_TEAM_TABLE=FCCoder-Team
DYNAMODB_MATCHES_TABLE=FCCoder-Matches

# How to set up DynamoDB:
# 1. Go to AWS DynamoDB console
# 2. Create three tables:
#    - FCCoder-Players (Partition key: id - String)
#    - FCCoder-Team (Partition key: id - String)
#    - FCCoder-Matches (Partition key: id - String)
# 3. Use the same AWS credentials as above
# 4. Run migration: POST /api/admin/migrate-db (requires admin token)